[Unit]
Description=TourBox Coach Setup gateway (port 80 — dashboard + CPD)
After=network-online.target ollama.service
Wants=network-online.target

[Service]
Type=simple
User=tourbox
Group=tourbox
WorkingDirectory=/home/tourbox/tourbox-coach
EnvironmentFile=/home/tourbox/tourbox-coach/.env
# Bind privileged port 80 without running the whole service as root.
# We only set AmbientCapabilities; don't restrict the bounding set, because
# our subprocess code calls `sudo nmcli -s` to read AP secrets and sudo's
# setuid escalation needs CAP_SETUID (which a tight bounding set would
# strip even from sudo-spawned children).
AmbientCapabilities=CAP_NET_BIND_SERVICE
ExecStart=/home/tourbox/tourbox-coach/venv/bin/uvicorn backend.setup_app:app --host 0.0.0.0 --port 80
Restart=on-failure
RestartSec=5
KillSignal=SIGTERM
TimeoutStopSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tourbox-setup

[Install]
WantedBy=multi-user.target
